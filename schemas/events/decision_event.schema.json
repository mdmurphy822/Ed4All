{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:ed4all:schemas:decision_event_schema",
  "title": "Claude Decision Event Schema",
  "description": "Schema for capturing Claude decisions during DART/Courseforge/Trainforge operations. Phase 0 Hardening adds event_id, seq, task_id, is_default, and outputs fields.",
  "type": "object",
  "required": ["run_id", "timestamp", "operation", "decision_type", "decision", "rationale"],
  "properties": {
    "event_id": {
      "type": ["string", "null"],
      "pattern": "^EVT_[a-f0-9]{16}$",
      "description": "Phase 0: Unique event identifier (EVT_<16-hex-chars>)"
    },
    "seq": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Phase 0: Monotonically increasing sequence number within run"
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this processing session (format: {TOOL}_{COURSE}_{YYYYMMDD_HHMMSS} or RUN_YYYYMMDD_HHMMSS_<uuid>)"
    },
    "course_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Z][A-Z0-9_-]{1,}$",
      "description": "Normalized course code. Admits both legacy underscore form (e.g., MTH_101) and post-Wave-93 hyphenated multi-segment slugs (e.g., RDF-SHACL-551-2)."
    },
    "module_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Z]{2,8}_[0-9]{3}_W[0-9]{2}_M[0-9]{2}$",
      "description": "Module identifier (e.g., MTH_101_W01_M02)"
    },
    "artifact_id": {
      "type": ["string", "null"],
      "description": "SHA256 hash (first 12 chars) of produced content"
    },
    "task_id": {
      "type": ["string", "null"],
      "pattern": "^T-[a-f0-9]{8}$",
      "description": "Phase 0: Orchestrator task ID for cross-linking decisions to tasks"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of decision"
    },
    "operation": {
      "type": "string",
      "description": "Explicit action label (e.g., generate_module_html, select_sources, convert_pdf)"
    },
    "phase": {
      "type": ["string", "null"],
      "enum": ["input-research", "exam-research", "course-outliner", "content-generator", "brightspace-packager", "dart-conversion", "dart-validation", "trainforge-assessment", "trainforge-training", "synthesize-training", "validation", "content-analysis", "question-generation", "assessment-assembly", "courseforge-input-research", "courseforge-exam-research", "courseforge-course-outliner", "courseforge-content-generator", "courseforge-brightspace-packager", "trainforge-content-analysis", "trainforge-question-generation", "trainforge-assessment-assembly", "trainforge-validation", "libv2-retrieval", "libv2-indexing", "libv2-fusion", null],
      "description": "Processing phase within the tool pipeline"
    },
    "tool": {
      "type": "string",
      "enum": ["dart", "courseforge", "trainforge", "orchestrator"],
      "description": "Which tool generated this decision"
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "abstention_generation",
        "accessibility_measures",
        "alignment_check",
        "alt_text_generation",
        "approach_selection",
        "assessment_design",
        "assessment_generation",
        "assessment_planning",
        "base_model_selection",
        "bloom_level_assignment",
        "boilerplate_strip",
        "chunk_deduplication",
        "chunk_retrieval",
        "chunk_selection",
        "chunk_serialization",
        "component_selection",
        "content_adaptation",
        "content_depth",
        "content_selection",
        "content_structure",
        "curriculum_alignment_call",
        "distractor_generation",
        "error_handling",
        "eval_gating_decision",
        "eval_run_decision",
        "example_selection",
        "existing_content_usage",
        "file_creation",
        "form_data_backfill_session",
        "form_data_degraded_placeholder_skipped",
        "format_decision",
        "heading_assignment",
        "hyperparameter_selection",
        "imscc_extraction",
        "index_strategy",
        "instruction_pair_synthesis",
        "kg_metadata_generation",
        "leak_check_filtering",
        "learning_objective_mapping",
        "llm_chat_call",
        "math_conversion",
        "misconception_pair_skipped",
        "model_promotion_decision",
        "objective_assessment",
        "outcome_signal",
        "paraphrase_used_deterministic_draft",
        "pedagogical_strategy",
        "pipeline_run_attribution",
        "preference_pair_generation",
        "prompt_response",
        "quality_judgment",
        "query_decomposition",
        "question_generation",
        "question_type_selection",
        "research_approach",
        "result_fusion",
        "retrieval_ranking",
        "revision_decision",
        "schema_translation_generation",
        "source_interpretation",
        "source_selection",
        "source_usage",
        "strategy_decision",
        "structure_detection",
        "synthesis_provider_call",
        "textbook_integration",
        "training_run_planning",
        "typed_edge_inference",
        "validation_result",
        "violation_generation"
      ],
      "description": "Category of decision from decision taxonomy (alphabetised; Wave 22 adds: assessment_generation, assessment_planning, boilerplate_strip, content_selection, pipeline_run_attribution, question_type_selection)"
    },
    "decision": {
      "type": "string",
      "minLength": 1,
      "description": "The decision made (what was chosen)"
    },
    "rationale": {
      "type": "string",
      "minLength": 20,
      "description": "Why this decision was made (critical for training - minimum 20 chars)"
    },
    "alternatives_considered": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "option": {"type": "string"},
          "score": {"type": "number"},
          "reason_rejected": {"type": "string"}
        }
      },
      "description": "Other options that were considered and why they were not chosen"
    },
    "context": {
      "type": ["string", "null"],
      "description": "Situational context for the decision"
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence level in this decision (0.0 to 1.0)"
    },
    "is_default": {
      "type": "boolean",
      "default": false,
      "description": "Phase 0: True if this captures a non-decision (default value used)"
    },
    "ml_features": {
      "type": ["object", "null"],
      "description": "Categorical fields for ML training",
      "properties": {
        "pedagogy_pattern": {
          "type": "string",
          "description": "Teaching approach pattern used"
        },
        "engagement_patterns": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Student engagement patterns targeted"
        },
        "cognitive_load_strategy": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Cognitive load management approaches"
        },
        "bloom_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"]
          },
          "description": "Bloom's taxonomy levels involved"
        },
        "udl_principles": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Universal Design for Learning principles applied"
        },
        "component_types": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Interactive component types used"
        }
      }
    },
    "inputs_ref": {
      "type": ["array", "null"],
      "description": "References to input sources used",
      "items": {
        "type": "object",
        "properties": {
          "source_type": {
            "type": "string",
            "enum": ["textbook", "existing_imscc", "web_search", "prompt_template", "assessment_bank", "pdf", "html", "agent_output"]
          },
          "path_or_id": {"type": "string"},
          "content_hash": {"type": "string"},
          "hash_algorithm": {
            "type": "string",
            "enum": ["sha256", "sha512", "blake3"],
            "default": "sha256",
            "description": "Phase 0: Algorithm used for content_hash"
          },
          "excerpt_range": {"type": "string"},
          "size_bytes": {
            "type": "integer",
            "minimum": 0,
            "description": "Phase 0: Size of content in bytes"
          },
          "byte_range": {
            "type": ["object", "null"],
            "description": "Phase 0: Byte range within file",
            "properties": {
              "start": {"type": "integer", "minimum": 0},
              "end": {"type": "integer", "minimum": 0}
            }
          }
        },
        "required": ["source_type", "path_or_id"]
      }
    },
    "prompt_ref": {
      "type": ["string", "null"],
      "description": "Prompt template version/hash used"
    },
    "outputs": {
      "type": ["array", "null"],
      "description": "Phase 0: Output artifact pointers (not blobs)",
      "items": {
        "type": "object",
        "properties": {
          "artifact_type": {
            "type": "string",
            "description": "Type of artifact (html, imscc, assessment, chunk, etc.)"
          },
          "path": {
            "type": "string",
            "description": "File path relative to run artifacts"
          },
          "content_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 hash of content"
          },
          "hash_algorithm": {
            "type": "string",
            "enum": ["sha256", "sha512", "blake3"],
            "default": "sha256"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": ["artifact_type", "path"]
      }
    },
    "outcome": {
      "type": ["object", "null"],
      "description": "Outcome signals for preference training (DPO/RLHF)",
      "properties": {
        "accepted": {"type": "boolean"},
        "revision_count": {"type": "integer"},
        "edit_distance": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        },
        "quality_metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "human_feedback": {"type": "string"}
      }
    },
    "metadata": {
      "type": ["object", "null"],
      "description": "Additional key-value pairs",
      "properties": {
        "rationale_length": {"type": "integer"},
        "quality_level": {
          "type": "string",
          "enum": ["exemplary", "proficient", "developing", "inadequate"]
        },
        "full_prompt": {"type": "string"},
        "full_response": {"type": "string"},
        "processing_time_ms": {"type": "number"},
        "token_count": {"type": "integer"},
        "quality_gate_passed": {"type": "boolean"},
        "quality_gate_reason": {"type": "string"},
        "validation_issues": {
          "type": ["array", "null"],
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  }
}
