# Courseforge JSON-LD SHACL Shapes v1 — Wave 63, hardened in Wave 67
#
# Companion to schemas/context/courseforge_v1.jsonld. Validates the RDF
# graph produced when a JSON-LD payload emitted by generate_course.py is
# processed through the Wave 62 @context. This gives Pearson / LRMI / CASE
# adopters an RDF-native validation surface alongside the JSON Schema at
# schemas/knowledge/courseforge_jsonld_v1.schema.json.
#
# Targeting strategy (Wave 67): every NodeShape targets an ed4all-namespaced
# class (ed4all:CourseModule / ed4all:LearningObjective / ed4all:Section
# etc.). The @context maps each JSON-LD @type alias to its ed4all: class
# directly; Schema.org inference is preserved via the Wave 65 vocabulary's
# `rdfs:subClassOf schema:LearningResource` / `schema:DefinedTerm` /
# `schema:CreativeWork` axioms. A Pearson-emitted schema:LearningResource
# in a mixed graph therefore does NOT fire our CourseModuleShape —
# Wave 63's over-targeting concern is closed.
#
# Vocabulary concept values (bloomLevel, cognitiveDomain, bloomRange,
# hierarchyLevel) are validated with `sh:in` against the canonical IRI set
# rather than `sh:pattern`. A typo like <https://ed4all.dev/vocab/bloom#aplly>
# falls outside the set and fails validation — Wave 63's pattern-based
# check would have accepted it.

@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:   <http://schema.org/> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix prov:     <http://www.w3.org/ns/prov#> .
@prefix ed4all:   <https://ed4all.dev/ns/courseforge/v1#> .
@prefix bloom:    <https://ed4all.dev/vocab/bloom#> .
@prefix cogdomain: <https://ed4all.dev/vocab/cognitive-domain#> .
@prefix hierarchy: <https://ed4all.dev/vocab/hierarchy#> .
@prefix cfshapes: <https://ed4all.dev/ns/courseforge/v1/shapes#> .

# ---------------------------------------------------------------------------
# Controlled-vocabulary concept declarations
# ---------------------------------------------------------------------------
# Declared inline so shapes using `sh:in ( bloom:remember ... )` don't require
# loading the Wave 65 vocabulary file separately during SHACL validation.
# Matches schemas/context/courseforge_v1.vocabulary.ttl — any drift is caught
# by schemas/tests/test_courseforge_vocabulary.py.

bloom:remember    a skos:Concept ; skos:prefLabel "Remember" .
bloom:understand  a skos:Concept ; skos:prefLabel "Understand" .
bloom:apply       a skos:Concept ; skos:prefLabel "Apply" .
bloom:analyze     a skos:Concept ; skos:prefLabel "Analyze" .
bloom:evaluate    a skos:Concept ; skos:prefLabel "Evaluate" .
bloom:create      a skos:Concept ; skos:prefLabel "Create" .

cogdomain:factual        a skos:Concept ; skos:prefLabel "Factual" .
cogdomain:conceptual     a skos:Concept ; skos:prefLabel "Conceptual" .
cogdomain:procedural     a skos:Concept ; skos:prefLabel "Procedural" .
cogdomain:metacognitive  a skos:Concept ; skos:prefLabel "Metacognitive" .

hierarchy:terminal  a skos:Concept ; skos:prefLabel "Terminal" .
hierarchy:chapter   a skos:Concept ; skos:prefLabel "Chapter" .

# ---------------------------------------------------------------------------
# CourseModuleShape — targets ed4all:CourseModule
# ---------------------------------------------------------------------------

cfshapes:CourseModuleShape
  a sh:NodeShape ;
  sh:targetClass ed4all:CourseModule ;
  rdfs:label "Courseforge CourseModule Shape" ;
  rdfs:comment "Validates the CourseModule JSON-LD payload emitted by generate_course.py::_build_page_metadata. Wave 67: targets ed4all:CourseModule (not schema:LearningResource) so Schema.org LearningResources from other emitters don't get validated against our required-predicate list." ;

  sh:property [
    sh:path schema:courseCode ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Z]{2,}_?\\d{3,}$" ;
    sh:message "courseCode must match ^[A-Z]{2,}_?\\d{3,}$ (e.g., SAMPLE_101, WCAG_201)." ;
  ] ;

  sh:property [
    sh:path schema:position ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 ;
    sh:message "weekNumber (schema:position) must be a non-negative integer." ;
  ] ;

  sh:property [
    sh:path schema:learningResourceType ;
    sh:minCount 1 ;
    sh:message "moduleType (schema:learningResourceType) is required on CourseModule." ;
  ] ;

  sh:property [
    sh:path schema:identifier ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minLength 1 ;
    sh:message "pageId (schema:identifier) is required and non-empty." ;
  ] ;

  # Wave 67 fix #5: explicit sh:node wiring so the relationship between parent
  # and child shape is declarative, not implicit via class targeting.
  sh:property [
    sh:path schema:teaches ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:LearningObjectiveShape ;
    sh:message "Each value of schema:teaches (learningObjectives[]) must conform to cfshapes:LearningObjectiveShape." ;
  ] ;

  sh:property [
    sh:path schema:hasPart ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:SectionShape ;
    sh:message "Each value of schema:hasPart (sections[]) must conform to cfshapes:SectionShape." ;
  ] ;

  # Wave 67 fix #6: hasMisconception now has a parent-scoped property
  # constraint (was previously only validated via class targeting).
  sh:property [
    sh:path ed4all:hasMisconception ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:MisconceptionShape ;
    sh:message "Each value of ed4all:hasMisconception (misconceptions[]) must conform to cfshapes:MisconceptionShape." ;
  ] ;

  sh:property [
    sh:path ed4all:bloomDistribution ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:BloomDistributionShape ;
    sh:message "bloomDistribution (when present, at most one) must be a single object conforming to cfshapes:BloomDistributionShape." ;
  ] .

# ---------------------------------------------------------------------------
# LearningObjectiveShape — targets ed4all:LearningObjective
# ---------------------------------------------------------------------------

cfshapes:LearningObjectiveShape
  a sh:NodeShape ;
  sh:targetClass ed4all:LearningObjective ;
  rdfs:label "Courseforge LearningObjective Shape" ;
  rdfs:comment "Validates LearningObjective JSON-LD emitted by generate_course.py::_build_objectives_metadata." ;

  sh:property [
    sh:path schema:description ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "LearningObjective.statement (schema:description) is required and non-empty." ;
  ] ;

  # Wave 67 fix #1: closed-set validation via sh:in rather than prefix
  # pattern. Catches typos like bloom#aplly that the pattern missed.
  sh:property [
    sh:path ed4all:bloomLevel ;
    sh:nodeKind sh:IRI ;
    sh:in (
      bloom:remember
      bloom:understand
      bloom:apply
      bloom:analyze
      bloom:evaluate
      bloom:create
    ) ;
    sh:message "bloomLevel must be one of bloom:remember / understand / apply / analyze / evaluate / create." ;
  ] ;

  sh:property [
    sh:path ed4all:cognitiveDomain ;
    sh:nodeKind sh:IRI ;
    sh:in (
      cogdomain:factual
      cogdomain:conceptual
      cogdomain:procedural
      cogdomain:metacognitive
    ) ;
    sh:message "cognitiveDomain must be one of cogdomain:factual / conceptual / procedural / metacognitive." ;
  ] ;

  sh:property [
    sh:path ed4all:hierarchyLevel ;
    sh:nodeKind sh:IRI ;
    sh:in ( hierarchy:terminal hierarchy:chapter ) ;
    sh:message "hierarchyLevel must be hierarchy:terminal or hierarchy:chapter." ;
  ] ;

  # Wave 67 fix #2: canonical LO pattern now enforced on the parent IRI.
  # The Wave 63 shape only required `sh:nodeKind sh:IRI`, letting any URL
  # pass through — including non-LO URIs.
  sh:property [
    sh:path ed4all:parentObjective ;
    sh:nodeKind sh:IRI ;
    sh:pattern ".*[/#](TO|CO)-\\d{2,}$" ;
    sh:message "parentObjectiveId must be an IRI whose local segment matches the canonical LO pattern (TO-NN or CO-NN)." ;
  ] ;

  sh:property [
    sh:path ed4all:targetsConcept ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:TargetedConceptShape ;
    sh:message "Each value of ed4all:targetsConcept (targetedConcepts[]) must conform to cfshapes:TargetedConceptShape." ;
  ] .

# ---------------------------------------------------------------------------
# SectionShape — Wave 67 fix #3 (was absent in Wave 63)
# ---------------------------------------------------------------------------

cfshapes:SectionShape
  a sh:NodeShape ;
  sh:targetClass ed4all:Section ;
  rdfs:label "Courseforge Section Shape" ;
  rdfs:comment "Wave 67: validates Section metadata emitted by generate_course.py::_build_sections_metadata. Previously absent — section payloads carrying no heading / malformed content type would validate silently." ;

  sh:property [
    sh:path schema:name ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "Section.heading (schema:name) is required and non-empty." ;
  ] ;

  # bloomRange values: canonical Bloom level as string literal.
  # Not an IRI because the @context drops @type:@vocab on bloomRange — pyld
  # can't cleanly expand @vocab + @container:@set items to IRIs, so we keep
  # them as literals and sh:in against the string enum.
  sh:property [
    sh:path ed4all:bloomRange ;
    sh:datatype xsd:string ;
    sh:in ( "remember" "understand" "apply" "analyze" "evaluate" "create" ) ;
    sh:message "Section.bloomRange entries must be canonical Bloom level strings." ;
  ] .

# ---------------------------------------------------------------------------
# TargetedConceptShape — ed4all:TargetedConcept
# ---------------------------------------------------------------------------

cfshapes:TargetedConceptShape
  a sh:NodeShape ;
  sh:targetClass ed4all:TargetedConcept ;
  rdfs:label "Courseforge TargetedConcept Shape" ;
  rdfs:comment "Validates the Wave 57 Bloom-qualified LO→concept edge." ;

  sh:property [
    sh:path schema:about ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "TargetedConcept.concept (schema:about) is required and must be an IRI." ;
  ] ;

  sh:property [
    sh:path ed4all:bloomLevel ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      bloom:remember
      bloom:understand
      bloom:apply
      bloom:analyze
      bloom:evaluate
      bloom:create
    ) ;
    sh:message "TargetedConcept.bloomLevel is required and must be a canonical bloom vocab IRI." ;
  ] .

# ---------------------------------------------------------------------------
# MisconceptionShape — ed4all:Misconception
# ---------------------------------------------------------------------------

cfshapes:MisconceptionShape
  a sh:NodeShape ;
  sh:targetClass ed4all:Misconception ;
  rdfs:label "Courseforge Misconception Shape" ;
  rdfs:comment "Validates Misconception JSON-LD emitted by _build_misconceptions_metadata. REC-JSL-01: both misconception + correction are required." ;

  sh:property [
    sh:path schema:description ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "Misconception.misconception (schema:description) is required and non-empty." ;
  ] ;

  sh:property [
    sh:path ed4all:correction ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "Misconception.correction (ed4all:correction) is required and non-empty." ;
  ] ;

  sh:property [
    sh:path ed4all:bloomLevel ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      bloom:remember
      bloom:understand
      bloom:apply
      bloom:analyze
      bloom:evaluate
      bloom:create
    ) ;
    sh:message "Misconception.bloomLevel must be a canonical bloom vocab IRI." ;
  ] ;

  sh:property [
    sh:path ed4all:cognitiveDomain ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      cogdomain:factual
      cogdomain:conceptual
      cogdomain:procedural
      cogdomain:metacognitive
    ) ;
    sh:message "Misconception.cognitiveDomain (when present) must be one of cogdomain:factual / conceptual / procedural / metacognitive." ;
  ] .

# ---------------------------------------------------------------------------
# BloomDistributionShape — ed4all:BloomDistribution (Wave 61)
# ---------------------------------------------------------------------------

cfshapes:BloomDistributionShape
  a sh:NodeShape ;
  sh:targetClass ed4all:BloomDistribution ;
  rdfs:label "Courseforge BloomDistribution Shape" ;
  rdfs:comment "Validates the per-page Bloom distribution aggregate (Wave 61)." ;

  sh:property [
    sh:path ed4all:total ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 ;
    sh:message "BloomDistribution.total is required and must be a non-negative integer." ;
  ] .

# ---------------------------------------------------------------------------
# ChunkShape — Wave 88 (closed-world ready)
# ---------------------------------------------------------------------------
# Targets ed4all:Chunk. Declares the authoritative predicate set for chunk
# nodes per chunk_v4_v1.jsonld (Wave 87 minted the 32 structural predicates +
# anchor classes). Shape-level constraint is identifier-only here; the
# closed-world assertion (sh:closed true) lives in the
# courseforge_v1.shacl-closed.ttl overlay, gated by
# TRAINFORGE_SHACL_CLOSED_WORLD=true. With the flag off, this shape simply
# requires every Chunk node carry a schema:identifier — the rest of the
# vocabulary stays open. With the flag on, the overlay adds sh:closed true
# and any predicate not in the {schema:identifier, cf:schemaVersion,
# cf:chunkType, cf:html, cf:summary, cf:retrievalText, cf:followsChunk,
# cf:positionInModule, cf:moduleId, cf:moduleTitle, cf:lessonId,
# cf:lessonTitle, cf:resourceType, cf:sectionHeading, cf:htmlXPath,
# cf:charSpan, cf:itemPath, cf:hasConceptTag, cf:learningOutcomeRef,
# cf:difficulty, cf:tokensEstimate, cf:wordCount, cf:bloomLevel,
# cf:bloomLevelSource, cf:bloomLevelSecondary, cf:hasKeyTerm,
# cf:hasTargetedConcept, cf:hasSource, cf:hasMisconception,
# cf:metadataTrace} authoritative set fires a closure violation.

cfshapes:ChunkShape
  a sh:NodeShape ;
  sh:targetClass ed4all:Chunk ;
  rdfs:label "Courseforge Chunk Shape" ;
  rdfs:comment "Wave 88: validates Trainforge content chunks emitted under chunk_v4_v1.jsonld. Open-world by default; closed-world enforcement is opt-in via courseforge_v1.shacl-closed.ttl when TRAINFORGE_SHACL_CLOSED_WORLD=true. Wave 87 minted the 32 structural predicates this shape would close against; Wave 88 ships the shape itself + the closed-world overlay." ;

  sh:property [
    sh:path schema:identifier ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "Chunk.identifier (schema:identifier) is required and non-empty." ;
  ] .

# ---------------------------------------------------------------------------
# TypedEdgeShape — Wave 88 (closed-world ready)
# ---------------------------------------------------------------------------
# Targets ed4all:TypedEdge. The reified-blank-node pattern used by
# concept_graph_semantic_v1.jsonld and pedagogy_graph_v1.jsonld emits each
# edge as an ed4all:TypedEdge instance carrying ed4all:source,
# ed4all:target, ed4all:edgeType, ed4all:confidence, plus per-rule
# provenance (ed4all:rule, ed4all:ruleVersionApplied, etc.). Shape-level
# constraint here is "edge_type required, source+target required" — the
# closed-world assertion lives in the overlay, gated by the same flag as
# ChunkShape.

cfshapes:TypedEdgeShape
  a sh:NodeShape ;
  sh:targetClass ed4all:TypedEdge ;
  rdfs:label "Courseforge TypedEdge Shape" ;
  rdfs:comment "Wave 88: validates the reified-blank-node TypedEdge pattern used by concept_graph_semantic_v1.jsonld + pedagogy_graph_v1.jsonld. Open-world by default; closed-world enforcement is opt-in via courseforge_v1.shacl-closed.ttl when TRAINFORGE_SHACL_CLOSED_WORLD=true." ;

  sh:property [
    sh:path ed4all:edgeType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "TypedEdge.edgeType (ed4all:edgeType) is required exactly once." ;
  ] ;

  sh:property [
    sh:path ed4all:source ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "TypedEdge.source (ed4all:source) is required and must be an IRI." ;
  ] ;

  sh:property [
    sh:path ed4all:target ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "TypedEdge.target (ed4all:target) is required and must be an IRI." ;
  ] .

# ---------------------------------------------------------------------------
# BlockShape — Phase 2 Subtask 13
# ---------------------------------------------------------------------------
# Targets ed4all:Block. Validates the canonical Phase 2 intermediate block
# (companion to Courseforge/scripts/blocks.py::Block). Mirrors the JSON
# Schema $defs/Block in schemas/knowledge/courseforge_jsonld_v1.schema.json.
#
# Shape contract:
#   - blockId: required, single, non-empty xsd:string.
#   - blockType: required, single, sh:in over the 16-value enum.
#   - sequence: required, single, xsd:integer minInclusive 0.
#   - contentHash: optional, single, xsd:string matching ^[a-f0-9]{64}$.
#   - touchedBy: optional list of TouchShape-conformant nodes (minCount 0).
#   - validationAttempts: optional, single, xsd:nonNegativeInteger
#       (Phase-3 regeneration-budget counter).
#   - escalationMarker: optional, single, sh:in over the 3-value enum
#       (Phase-3 escalation tag).

cfshapes:BlockShape
  a sh:NodeShape ;
  sh:targetClass ed4all:Block ;
  rdfs:label "Courseforge Block Shape" ;
  rdfs:comment "Phase 2 Subtask 13: validates the canonical intermediate Block companion to Courseforge/scripts/blocks.py::Block. Phase-3 fields validationAttempts + escalationMarker support the per-block regeneration-budget primitive." ;

  sh:property [
    sh:path ed4all:blockId ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:message "Block.blockId is required, single, and non-empty." ;
  ] ;

  sh:property [
    sh:path ed4all:blockType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in (
      "objective"
      "concept"
      "example"
      "assessment_item"
      "explanation"
      "prereq_set"
      "activity"
      "misconception"
      "callout"
      "flip_card_grid"
      "self_check_question"
      "summary_takeaway"
      "reflection_prompt"
      "discussion_prompt"
      "chrome"
      "recap"
    ) ;
    sh:message "Block.blockType must be one of the 16 canonical Phase 2 block types." ;
  ] ;

  sh:property [
    sh:path ed4all:sequence ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 ;
    sh:message "Block.sequence is required, single, and a non-negative integer." ;
  ] ;

  sh:property [
    sh:path ed4all:contentHash ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:pattern "^[a-f0-9]{64}$" ;
    sh:message "Block.contentHash (when present) must be a 64-char lowercase hex string (sha256)." ;
  ] ;

  sh:property [
    sh:path ed4all:touchedBy ;
    sh:minCount 0 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:TouchShape ;
    sh:message "Each value of ed4all:touchedBy (touched_by[]) must conform to cfshapes:TouchShape." ;
  ] ;

  sh:property [
    sh:path ed4all:validationAttempts ;
    sh:maxCount 1 ;
    sh:datatype xsd:nonNegativeInteger ;
    sh:message "Block.validationAttempts (when present) must be a single non-negative integer (Phase-3 regeneration-budget counter)." ;
  ] ;

  sh:property [
    sh:path ed4all:escalationMarker ;
    sh:maxCount 1 ;
    sh:in (
      "outline_budget_exhausted"
      "structural_unfixable"
      "validator_consensus_fail"
    ) ;
    sh:message "Block.escalationMarker (when present) must be one of the canonical Phase-3 escalation markers." ;
  ] .

# ---------------------------------------------------------------------------
# TouchShape — Phase 2 Subtask 13
# ---------------------------------------------------------------------------
# Targets ed4all:Touch. Validates one revision attribution event in a Block's
# touch chain (companion to Courseforge/scripts/blocks.py::Touch). Wave 112
# invariant: decisionCaptureId is non-empty.

cfshapes:TouchShape
  a sh:NodeShape ;
  sh:targetClass ed4all:Touch ;
  rdfs:label "Courseforge Touch Shape" ;
  rdfs:comment "Phase 2 Subtask 13: validates one revision attribution event. Wave 112 invariant: decisionCaptureId is non-empty by construction." ;

  # Phase 3.5 Subtask 15: extend Touch.tier with the post-validation
  # tier labels ``outline_val`` / ``rewrite_val`` so SHACL accepts
  # validator-emitted Touches alongside the legacy authoring-tier set.
  sh:property [
    sh:path ed4all:tier ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "outline" "validation" "rewrite" "outline_val" "rewrite_val" ) ;
    sh:message "Touch.tier is required and must be one of outline / validation / rewrite / outline_val / rewrite_val." ;
  ] ;

  sh:property [
    sh:path ed4all:provider ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "anthropic" "local" "together" "claude_session" "deterministic" ) ;
    sh:message "Touch.provider is required and must be one of the 5 canonical providers." ;
  ] ;

  sh:property [
    sh:path ed4all:decisionCaptureId ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minLength 1 ;
    sh:message "Touch.decisionCaptureId is required and non-empty (Wave 112 invariant)." ;
  ] .
