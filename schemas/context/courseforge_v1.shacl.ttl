# Courseforge JSON-LD SHACL Shapes v1 — Wave 63, hardened in Wave 67
#
# Companion to schemas/context/courseforge_v1.jsonld. Validates the RDF
# graph produced when a JSON-LD payload emitted by generate_course.py is
# processed through the Wave 62 @context. This gives Pearson / LRMI / CASE
# adopters an RDF-native validation surface alongside the JSON Schema at
# schemas/knowledge/courseforge_jsonld_v1.schema.json.
#
# Targeting strategy (Wave 67): every NodeShape targets an ed4all-namespaced
# class (ed4all:CourseModule / ed4all:LearningObjective / ed4all:Section
# etc.). The @context maps each JSON-LD @type alias to its ed4all: class
# directly; Schema.org inference is preserved via the Wave 65 vocabulary's
# `rdfs:subClassOf schema:LearningResource` / `schema:DefinedTerm` /
# `schema:CreativeWork` axioms. A Pearson-emitted schema:LearningResource
# in a mixed graph therefore does NOT fire our CourseModuleShape —
# Wave 63's over-targeting concern is closed.
#
# Vocabulary concept values (bloomLevel, cognitiveDomain, bloomRange,
# hierarchyLevel) are validated with `sh:in` against the canonical IRI set
# rather than `sh:pattern`. A typo like <https://ed4all.dev/vocab/bloom#aplly>
# falls outside the set and fails validation — Wave 63's pattern-based
# check would have accepted it.

@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix schema:   <http://schema.org/> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix prov:     <http://www.w3.org/ns/prov#> .
@prefix ed4all:   <https://ed4all.dev/ns/courseforge/v1#> .
@prefix bloom:    <https://ed4all.dev/vocab/bloom#> .
@prefix cogdomain: <https://ed4all.dev/vocab/cognitive-domain#> .
@prefix hierarchy: <https://ed4all.dev/vocab/hierarchy#> .
@prefix cfshapes: <https://ed4all.dev/ns/courseforge/v1/shapes#> .

# ---------------------------------------------------------------------------
# Controlled-vocabulary concept declarations
# ---------------------------------------------------------------------------
# Declared inline so shapes using `sh:in ( bloom:remember ... )` don't require
# loading the Wave 65 vocabulary file separately during SHACL validation.
# Matches schemas/context/courseforge_v1.vocabulary.ttl — any drift is caught
# by schemas/tests/test_courseforge_vocabulary.py.

bloom:remember    a skos:Concept ; skos:prefLabel "Remember" .
bloom:understand  a skos:Concept ; skos:prefLabel "Understand" .
bloom:apply       a skos:Concept ; skos:prefLabel "Apply" .
bloom:analyze     a skos:Concept ; skos:prefLabel "Analyze" .
bloom:evaluate    a skos:Concept ; skos:prefLabel "Evaluate" .
bloom:create      a skos:Concept ; skos:prefLabel "Create" .

cogdomain:factual        a skos:Concept ; skos:prefLabel "Factual" .
cogdomain:conceptual     a skos:Concept ; skos:prefLabel "Conceptual" .
cogdomain:procedural     a skos:Concept ; skos:prefLabel "Procedural" .
cogdomain:metacognitive  a skos:Concept ; skos:prefLabel "Metacognitive" .

hierarchy:terminal  a skos:Concept ; skos:prefLabel "Terminal" .
hierarchy:chapter   a skos:Concept ; skos:prefLabel "Chapter" .

# ---------------------------------------------------------------------------
# CourseModuleShape — targets ed4all:CourseModule
# ---------------------------------------------------------------------------

cfshapes:CourseModuleShape
  a sh:NodeShape ;
  sh:targetClass ed4all:CourseModule ;
  rdfs:label "Courseforge CourseModule Shape" ;
  rdfs:comment "Validates the CourseModule JSON-LD payload emitted by generate_course.py::_build_page_metadata. Wave 67: targets ed4all:CourseModule (not schema:LearningResource) so Schema.org LearningResources from other emitters don't get validated against our required-predicate list." ;

  sh:property [
    sh:path schema:courseCode ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Z]{2,}_?\\d{3,}$" ;
    sh:message "courseCode must match ^[A-Z]{2,}_?\\d{3,}$ (e.g., SAMPLE_101, WCAG_201)." ;
  ] ;

  sh:property [
    sh:path schema:position ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 ;
    sh:message "weekNumber (schema:position) must be a non-negative integer." ;
  ] ;

  sh:property [
    sh:path schema:learningResourceType ;
    sh:minCount 1 ;
    sh:message "moduleType (schema:learningResourceType) is required on CourseModule." ;
  ] ;

  sh:property [
    sh:path schema:identifier ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minLength 1 ;
    sh:message "pageId (schema:identifier) is required and non-empty." ;
  ] ;

  # Wave 67 fix #5: explicit sh:node wiring so the relationship between parent
  # and child shape is declarative, not implicit via class targeting.
  sh:property [
    sh:path schema:teaches ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:LearningObjectiveShape ;
    sh:message "Each value of schema:teaches (learningObjectives[]) must conform to cfshapes:LearningObjectiveShape." ;
  ] ;

  sh:property [
    sh:path schema:hasPart ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:SectionShape ;
    sh:message "Each value of schema:hasPart (sections[]) must conform to cfshapes:SectionShape." ;
  ] ;

  # Wave 67 fix #6: hasMisconception now has a parent-scoped property
  # constraint (was previously only validated via class targeting).
  sh:property [
    sh:path ed4all:hasMisconception ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:MisconceptionShape ;
  ] ;

  sh:property [
    sh:path ed4all:bloomDistribution ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:BloomDistributionShape ;
  ] .

# ---------------------------------------------------------------------------
# LearningObjectiveShape — targets ed4all:LearningObjective
# ---------------------------------------------------------------------------

cfshapes:LearningObjectiveShape
  a sh:NodeShape ;
  sh:targetClass ed4all:LearningObjective ;
  rdfs:label "Courseforge LearningObjective Shape" ;
  rdfs:comment "Validates LearningObjective JSON-LD emitted by generate_course.py::_build_objectives_metadata." ;

  sh:property [
    sh:path schema:description ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "LearningObjective.statement (schema:description) is required and non-empty." ;
  ] ;

  # Wave 67 fix #1: closed-set validation via sh:in rather than prefix
  # pattern. Catches typos like bloom#aplly that the pattern missed.
  sh:property [
    sh:path ed4all:bloomLevel ;
    sh:nodeKind sh:IRI ;
    sh:in (
      bloom:remember
      bloom:understand
      bloom:apply
      bloom:analyze
      bloom:evaluate
      bloom:create
    ) ;
    sh:message "bloomLevel must be one of bloom:remember / understand / apply / analyze / evaluate / create." ;
  ] ;

  sh:property [
    sh:path ed4all:cognitiveDomain ;
    sh:nodeKind sh:IRI ;
    sh:in (
      cogdomain:factual
      cogdomain:conceptual
      cogdomain:procedural
      cogdomain:metacognitive
    ) ;
    sh:message "cognitiveDomain must be one of cogdomain:factual / conceptual / procedural / metacognitive." ;
  ] ;

  sh:property [
    sh:path ed4all:hierarchyLevel ;
    sh:nodeKind sh:IRI ;
    sh:in ( hierarchy:terminal hierarchy:chapter ) ;
    sh:message "hierarchyLevel must be hierarchy:terminal or hierarchy:chapter." ;
  ] ;

  # Wave 67 fix #2: canonical LO pattern now enforced on the parent IRI.
  # The Wave 63 shape only required `sh:nodeKind sh:IRI`, letting any URL
  # pass through — including non-LO URIs.
  sh:property [
    sh:path ed4all:parentObjective ;
    sh:nodeKind sh:IRI ;
    sh:pattern ".*[/#](TO|CO)-\\d{2,}$" ;
    sh:message "parentObjectiveId must be an IRI whose local segment matches the canonical LO pattern (TO-NN or CO-NN)." ;
  ] ;

  sh:property [
    sh:path ed4all:targetsConcept ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:node cfshapes:TargetedConceptShape ;
  ] .

# ---------------------------------------------------------------------------
# SectionShape — Wave 67 fix #3 (was absent in Wave 63)
# ---------------------------------------------------------------------------

cfshapes:SectionShape
  a sh:NodeShape ;
  sh:targetClass ed4all:Section ;
  rdfs:label "Courseforge Section Shape" ;
  rdfs:comment "Wave 67: validates Section metadata emitted by generate_course.py::_build_sections_metadata. Previously absent — section payloads carrying no heading / malformed content type would validate silently." ;

  sh:property [
    sh:path schema:name ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "Section.heading (schema:name) is required and non-empty." ;
  ] ;

  # bloomRange values: canonical Bloom level as string literal.
  # Not an IRI because the @context drops @type:@vocab on bloomRange — pyld
  # can't cleanly expand @vocab + @container:@set items to IRIs, so we keep
  # them as literals and sh:in against the string enum.
  sh:property [
    sh:path ed4all:bloomRange ;
    sh:datatype xsd:string ;
    sh:in ( "remember" "understand" "apply" "analyze" "evaluate" "create" ) ;
    sh:message "Section.bloomRange entries must be canonical Bloom level strings." ;
  ] .

# ---------------------------------------------------------------------------
# TargetedConceptShape — ed4all:TargetedConcept
# ---------------------------------------------------------------------------

cfshapes:TargetedConceptShape
  a sh:NodeShape ;
  sh:targetClass ed4all:TargetedConcept ;
  rdfs:label "Courseforge TargetedConcept Shape" ;
  rdfs:comment "Validates the Wave 57 Bloom-qualified LO→concept edge." ;

  sh:property [
    sh:path schema:about ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:message "TargetedConcept.concept (schema:about) is required and must be an IRI." ;
  ] ;

  sh:property [
    sh:path ed4all:bloomLevel ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      bloom:remember
      bloom:understand
      bloom:apply
      bloom:analyze
      bloom:evaluate
      bloom:create
    ) ;
    sh:message "TargetedConcept.bloomLevel is required and must be a canonical bloom vocab IRI." ;
  ] .

# ---------------------------------------------------------------------------
# MisconceptionShape — ed4all:Misconception
# ---------------------------------------------------------------------------

cfshapes:MisconceptionShape
  a sh:NodeShape ;
  sh:targetClass ed4all:Misconception ;
  rdfs:label "Courseforge Misconception Shape" ;
  rdfs:comment "Validates Misconception JSON-LD emitted by _build_misconceptions_metadata. REC-JSL-01: both misconception + correction are required." ;

  sh:property [
    sh:path schema:description ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "Misconception.misconception (schema:description) is required and non-empty." ;
  ] ;

  sh:property [
    sh:path ed4all:correction ;
    sh:minCount 1 ;
    sh:minLength 1 ;
    sh:message "Misconception.correction (ed4all:correction) is required and non-empty." ;
  ] ;

  sh:property [
    sh:path ed4all:bloomLevel ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      bloom:remember
      bloom:understand
      bloom:apply
      bloom:analyze
      bloom:evaluate
      bloom:create
    ) ;
    sh:message "Misconception.bloomLevel must be a canonical bloom vocab IRI." ;
  ] ;

  sh:property [
    sh:path ed4all:cognitiveDomain ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:in (
      cogdomain:factual
      cogdomain:conceptual
      cogdomain:procedural
      cogdomain:metacognitive
    ) ;
  ] .

# ---------------------------------------------------------------------------
# BloomDistributionShape — ed4all:BloomDistribution (Wave 61)
# ---------------------------------------------------------------------------

cfshapes:BloomDistributionShape
  a sh:NodeShape ;
  sh:targetClass ed4all:BloomDistribution ;
  rdfs:label "Courseforge BloomDistribution Shape" ;
  rdfs:comment "Validates the per-page Bloom distribution aggregate (Wave 61)." ;

  sh:property [
    sh:path ed4all:total ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 ;
    sh:message "BloomDistribution.total is required and must be a non-negative integer." ;
  ] .
