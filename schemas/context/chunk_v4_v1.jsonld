{
  "_description": "Chunk v4 JSON-LD @context — Phase 1.2 of plans/rdf-shacl-enrichment-2026-04-26.md. Layered on top of a single chunk record (schemas/knowledge/chunk_v4.schema.json — emitted by Trainforge/process_course.py to corpus/chunks.jsonl) so the existing JSON round-trips as RDF triples without rewriting the data. Like Phase 1.1's concept_graph_semantic_v1.jsonld, this is consumer-side only — the Trainforge chunk emit pipeline does NOT inject this context (Phase 1 spans tests + on-demand Turtle exports only). Three design decisions worth flagging: (1) Predicate reuse with Phase 1.1 — the chunk-level `id` and the source.source_references[] sub-shape both intersect Worker A's concept_graph_semantic_v1.jsonld vocabulary. We reuse `ed4all:chunkId` (chunk-as-subject IRI generation hook), `ed4all:loId` (LO refs are already declared as ed4all:loId in Phase 1.1), `ed4all:bloomLevel` / `ed4all:cognitiveDomain` / `ed4all:evidenceContentType` (Bloom + content-type vocab routing), `ed4all:term` / `ed4all:definitionExcerpt` (KeyTerm sub-shape mirrors concept-graph definedBy evidence), `ed4all:misconceptionId` + `ed4all:concept` (misconception sub-shape), `ed4all:courseId` / `ed4all:runId` (provenance). The five Misconception fields (statement, correction, bloomLevel, cognitiveDomain) reuse Phase 1.1 predicates where they already exist. (2) Newly used predicates flagged for Phase 2 follow-up — these IRIs are NOT yet declared in schemas/context/courseforge_v1.vocabulary.ttl (Phase 2.1 vocabulary file). They are listed in the `_phase2_followup` block below for Worker B to formally declare with rdfs:domain/rdfs:range axioms in Phase 2 of the enrichment plan. Until then the IRI strings remain authoritative and round-trip cleanly through pyld + rdflib; downstream RDFS reasoning will simply not get inheritance until the formal declarations land. (3) Namespace alignment — per the Phase 1.2 instructions (and matching Phase 1.1 `concept_graph_semantic_v1.jsonld` line 14), this context uses `https://ed4all.io/vocab/` rather than the Phase 2.1 vocabulary file's `https://ed4all.dev/ns/courseforge/v1#`. The two namespaces co-exist during Phase 1; a Phase 2 reconciliation will pick one. The chunk-level @base resolves chunk IDs as `https://ed4all.io/chunk/{chunk_id}` (parallel to Phase 1.1's `https://ed4all.io/concept/{slug}`) so a JSON-LD processor materializes every chunk as a stable IRI rather than a blank node. The `source.source_references[]` sub-shape projects the canonical schemas/knowledge/source_reference.schema.json fields onto typed predicates (`ed4all:sourceId`, `ed4all:sourceRole`, `ed4all:sourceWeight`, `ed4all:sourceConfidence`, `ed4all:sourcePages`, `ed4all:sourceExtractor`); each ref is a typed `ed4all:SourceReference` blank node so per-ref provenance survives round-trip. This sibling '_description' key lives outside the @context block so JSON-LD 1.1 processors don't parse it as a term definition.",
  "_phase3_followup": {
    "_description": "Predicate IRIs used in this @context that remain undeclared in schemas/context/courseforge_v1.vocabulary.ttl after Wave 87 minted the 33 chunk-structural predicates + 2 anchor classes (KeyTerm, SourceReference). Wave 87 closed all but one: ed4all:metadataTrace (the Worker M1 _metadata_trace diagnostic dict) has an open-shape problem — its value is a dict whose keys are arbitrary enrichment-field names, so a useful rdfs:range target is undecidable today. Resolving this requires either (a) declaring an rdfs:Class wrapper with a constrained property surface, or (b) declaring rdfs:range rdf:Property and treating each key as an annotation predicate; either choice constrains future enrichment-field additions. Deferred to a later wave that can pair the declaration with an emit-side schema lockdown.",
    "predicates": [
      "ed4all:metadataTrace"
    ]
  },
  "@context": {
    "@version": 1.1,
    "@base": "https://ed4all.io/chunk/",

    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "schema": "http://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ed4all": "https://ed4all.io/vocab/",

    "Chunk": "ed4all:Chunk",
    "SourceReference": "ed4all:SourceReference",
    "KeyTerm": "ed4all:KeyTerm",
    "Misconception": "ed4all:Misconception",
    "TargetedConcept": "ed4all:TargetedConcept",

    "id": "@id",
    "schema_version": { "@id": "ed4all:schemaVersion", "@type": "xsd:string" },
    "chunk_type": {
      "@id": "ed4all:chunkType",
      "@type": "@vocab",
      "@context": { "@vocab": "https://ed4all.io/vocab/chunk-type#" }
    },
    "text": { "@id": "schema:text", "@type": "xsd:string" },
    "html": { "@id": "ed4all:html", "@type": "xsd:string" },
    "follows_chunk": { "@id": "ed4all:followsChunk", "@type": "@id" },

    "concept_tags": {
      "@id": "ed4all:hasConceptTag",
      "@container": "@set"
    },
    "learning_outcome_refs": {
      "@id": "ed4all:loId",
      "@container": "@set"
    },
    "difficulty": {
      "@id": "ed4all:difficulty",
      "@type": "@vocab",
      "@context": { "@vocab": "https://ed4all.io/vocab/difficulty#" }
    },
    "tokens_estimate": { "@id": "ed4all:tokensEstimate", "@type": "xsd:integer" },
    "word_count": { "@id": "ed4all:wordCount", "@type": "xsd:integer" },
    "bloom_level": {
      "@id": "ed4all:bloomLevel",
      "@type": "@vocab",
      "@context": { "@vocab": "https://ed4all.io/vocab/bloom#" }
    },
    "bloom_level_source": { "@id": "ed4all:bloomLevelSource", "@type": "xsd:string" },
    "bloom_level_secondary": {
      "@id": "ed4all:bloomLevelSecondary",
      "@type": "@vocab",
      "@context": { "@vocab": "https://ed4all.io/vocab/bloom#" }
    },
    "content_type_label": {
      "@id": "ed4all:evidenceContentType",
      "@type": "@vocab",
      "@context": { "@vocab": "https://ed4all.io/vocab/evidence-content-type#" }
    },
    "summary": { "@id": "ed4all:summary", "@type": "xsd:string" },
    "retrieval_text": { "@id": "ed4all:retrievalText", "@type": "xsd:string" },
    "_metadata_trace": "ed4all:metadataTrace",
    "run_id": { "@id": "prov:wasGeneratedBy", "@type": "@id" },
    "created_at": { "@id": "dcterms:created", "@type": "xsd:dateTime" },

    "source": { "@id": "ed4all:hasSource" },

    "course_id": { "@id": "ed4all:courseId", "@type": "xsd:string" },
    "module_id": { "@id": "ed4all:moduleId", "@type": "xsd:string" },
    "module_title": { "@id": "ed4all:moduleTitle", "@type": "xsd:string" },
    "lesson_id": { "@id": "ed4all:lessonId", "@type": "xsd:string" },
    "lesson_title": { "@id": "ed4all:lessonTitle", "@type": "xsd:string" },
    "resource_type": { "@id": "ed4all:resourceType", "@type": "xsd:string" },
    "section_heading": { "@id": "ed4all:sectionHeading", "@type": "xsd:string" },
    "position_in_module": { "@id": "ed4all:positionInModule", "@type": "xsd:integer" },
    "html_xpath": { "@id": "ed4all:htmlXPath", "@type": "xsd:string" },
    "char_span": {
      "@id": "ed4all:charSpan",
      "@type": "xsd:integer",
      "@container": "@list"
    },
    "item_path": { "@id": "ed4all:itemPath", "@type": "xsd:string" },

    "source_references": {
      "@id": "ed4all:sourceReference",
      "@container": "@set"
    },
    "sourceId": { "@id": "ed4all:sourceId", "@type": "xsd:string" },
    "role": { "@id": "ed4all:sourceRole", "@type": "xsd:string" },
    "weight": { "@id": "ed4all:sourceWeight", "@type": "xsd:decimal" },
    "confidence": { "@id": "ed4all:sourceConfidence", "@type": "xsd:decimal" },
    "pages": {
      "@id": "ed4all:sourcePages",
      "@type": "xsd:integer",
      "@container": "@list"
    },
    "extractor": { "@id": "ed4all:sourceExtractor", "@type": "xsd:string" },

    "key_terms": {
      "@id": "ed4all:hasKeyTerm",
      "@container": "@set"
    },
    "term": { "@id": "ed4all:term", "@type": "xsd:string" },
    "definition": { "@id": "ed4all:definitionExcerpt", "@type": "xsd:string" },

    "misconceptions": {
      "@id": "ed4all:hasMisconception",
      "@container": "@set"
    },
    "misconception": { "@id": "ed4all:misconceptionStatement", "@type": "xsd:string" },
    "statement": { "@id": "ed4all:misconceptionStatement", "@type": "xsd:string" },
    "correction": { "@id": "ed4all:correction", "@type": "xsd:string" },
    "cognitive_domain": {
      "@id": "ed4all:cognitiveDomain",
      "@type": "@vocab",
      "@context": { "@vocab": "https://ed4all.io/vocab/cognitive-domain#" }
    },

    "targeted_concepts": {
      "@id": "ed4all:hasTargetedConcept",
      "@container": "@set"
    },
    "concept": { "@id": "ed4all:concept", "@type": "xsd:string" }
  }
}
