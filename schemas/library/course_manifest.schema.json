{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://libv2.local/schema/course_manifest.schema.json",
  "title": "Course Manifest",
  "description": "Extended metadata for a course in the LibV2 repository",
  "type": "object",
  "required": ["libv2_version", "slug", "import_timestamp", "sourceforge_manifest", "classification", "content_profile", "dart_chunks_sha256", "imscc_chunks_sha256", "concept_graph_sha256"],
  "properties": {
    "libv2_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "LibV2 schema version"
    },
    "chunker_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[+-][A-Za-z0-9.+-]+)?$",
      "description": "Phase 7a Subtask 8: version of the ed4all-chunker package that produced the archived chunks. Read at archive time via importlib.metadata.version('ed4all-chunker'). Optional in Phase 7a (Wave 7); promoted to required by the Phase 7c validator wiring once both the DART chunkset (Phase 7b) and IMSCC chunkset (Phase 7c) emitters are settled. Pattern accepts standard semver plus optional +local / -prerelease suffixes (e.g. '0.1.0', '0.1.0+missing', '1.0.0-rc1') so a fallback marker can be emitted when the package isn't installed without breaking schema validation."
    },
    "concept_graph_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Phase 6 Subtask 17: SHA-256 of concept_graph_semantic.json produced by the concept_extraction workflow phase. Promoted to required by Phase 7c Subtask 17 alongside dart_chunks_sha256 + imscc_chunks_sha256 — the LibV2ManifestValidator now fail-closes when any of the three chunkset/graph hashes is absent."
    },
    "dart_chunks_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Phase 7b/7c: SHA-256 of LibV2/courses/<slug>/dart_chunks/chunks.jsonl produced by the chunking workflow phase (Phase 7b ST 11). Required by Phase 7c Subtask 17; ties the archived DART chunkset to the course manifest. Validator: lib.validators.libv2_manifest.LibV2ManifestValidator._check_dart_chunks_sha256."
    },
    "imscc_chunks_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "Phase 7c: SHA-256 of LibV2/courses/<slug>/imscc_chunks/chunks.jsonl produced by the imscc_chunking workflow phase (Phase 7c ST 16). Required by Phase 7c Subtask 17; ties the archived IMSCC chunkset to the course manifest. Validator: lib.validators.libv2_manifest.LibV2ManifestValidator._check_imscc_chunks_sha256."
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 3,
      "maxLength": 100,
      "description": "URL-safe unique identifier"
    },
    "import_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the course was imported to LibV2"
    },
    "sourceforge_manifest": {
      "type": "object",
      "required": ["sourceforge_version", "export_timestamp", "course_id", "course_title"],
      "properties": {
        "sourceforge_version": {
          "type": "string",
          "description": "Sourceforge version that produced this output"
        },
        "export_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "course_id": {
          "type": "string",
          "description": "Original course identifier from Sourceforge"
        },
        "course_title": {
          "type": "string",
          "description": "Human-readable course title"
        }
      }
    },
    "eval_profile": {
      "type": "string",
      "enum": ["generic", "rdf_shacl"],
      "description": "Wave 132c: explicit Trainforge eval-harness profile. When set, Trainforge.eval.slm_eval_harness._resolve_default_profile uses this value directly instead of substring-sniffing classification fields. Add new enum values when authoring new Trainforge/eval/configs/<name>.yaml profiles."
    },
    "classification": {
      "type": "object",
      "required": ["division", "primary_domain"],
      "properties": {
        "division": {
          "type": "string",
          "enum": ["STEM", "ARTS"],
          "description": "Top-level division"
        },
        "primary_domain": {
          "type": "string",
          "description": "Main domain classification"
        },
        "secondary_domains": {
          "type": "array",
          "items": {"type": "string"},
          "default": [],
          "description": "Additional relevant domains"
        },
        "subdomains": {
          "type": "array",
          "items": {"type": "string"},
          "default": [],
          "description": "Specific subdomains within the domain"
        },
        "topics": {
          "type": "array",
          "items": {"type": "string"},
          "default": [],
          "description": "Specific topics covered"
        },
        "subtopics": {
          "type": "array",
          "items": {"type": "string"},
          "default": [],
          "description": "Granular subtopics"
        },
        "tags": {
          "type": "array",
          "items": {"type": "string"},
          "default": [],
          "description": "Wave 133f: HuggingFace model-card tags appended to the default ['education','qlora','peft','trainforge',<slug>] list when an adapter for this course publishes. Replaces the substring sniff in Trainforge.eval.hf_model_index.write_hf_readme — manifest-driven so non-RDF/SHACL courses can declare their own discovery tags without code changes."
        }
      }
    },
    "ontology_mappings": {
      "type": "object",
      "properties": {
        "acm_ccs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "term"],
            "properties": {
              "code": {"type": "string"},
              "term": {"type": "string"},
              "relevance": {"type": "integer", "minimum": 0, "maximum": 1000}
            }
          },
          "description": "ACM Computing Classification System mappings"
        },
        "lcsh": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["uri", "term"],
            "properties": {
              "uri": {"type": "string"},
              "term": {"type": "string"},
              "type": {"type": "string", "enum": ["primary", "related", "broader", "narrower"]}
            }
          },
          "description": "Library of Congress Subject Headings"
        }
      }
    },
    "relationships": {
      "type": "object",
      "properties": {
        "prerequisites": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Course slugs that should be completed before this one"
        },
        "related_courses": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Related course slugs"
        },
        "successor_courses": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Courses that build on this one"
        }
      }
    },
    "content_profile": {
      "type": "object",
      "required": ["total_chunks", "total_tokens"],
      "properties": {
        "difficulty_distribution": {
          "type": "object",
          "properties": {
            "foundational": {"type": "integer", "minimum": 0},
            "intermediate": {"type": "integer", "minimum": 0},
            "advanced": {"type": "integer", "minimum": 0}
          }
        },
        "chunk_type_distribution": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "total_chunks": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_concepts": {
          "type": "integer",
          "minimum": 0
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}$",
          "default": "en"
        }
      }
    },
    "quality_metadata": {
      "type": "object",
      "properties": {
        "validation_status": {
          "type": "string",
          "enum": ["pending", "validated", "failed"]
        },
        "last_validated": {
          "type": "string",
          "format": "date-time"
        },
        "completeness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "annotation_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source_type": {
          "type": "string",
          "description": "Original format (imscc, pdf, epub, etc.)"
        },
        "source_path": {
          "type": "string",
          "description": "Original file path"
        },
        "original_provider": {
          "type": "string",
          "description": "Content provider or institution"
        },
        "import_pipeline_version": {
          "type": "string"
        }
      }
    }
  }
}
