{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ed4all/schemas/training/property_manifest.schema.json",
  "title": "Property Manifest",
  "description": "Wave 109 / Phase C: Declares the canonical surface forms a course-specific SLM adapter must teach. The synthesis-side PropertyCoverageValidator and the eval-side PerPropertyEvaluator both consume this manifest.",
  "type": "object",
  "required": ["course_slug", "properties"],
  "properties": {
    "course_slug": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "properties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "uri", "curie", "label", "surface_forms", "min_pairs"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "uri": {"type": "string", "format": "uri"},
          "curie": {"type": "string", "pattern": "^[a-z]+:[A-Za-z][A-Za-z0-9_]*$"},
          "label": {"type": "string", "minLength": 1},
          "surface_forms": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "min_pairs": {"type": "integer", "minimum": 1},
          "min_accuracy": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
