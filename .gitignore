# =============================================================================
# Ed4All - LibV2 Content (preserve structure, exclude data)
# =============================================================================
LibV2/courses/*
!LibV2/courses/.gitkeep
# Per-course reference-retrieval artifacts (Worker J).  Only the hand-curated
# gold queries + their README ride in git; chunks.jsonl, evaluation_results.json,
# and everything else under courses/*/ stays local.
!LibV2/courses/*/
!LibV2/courses/*/retrieval/
!LibV2/courses/*/retrieval/gold_queries.jsonl
!LibV2/courses/*/retrieval/README.md
LibV2/catalog/*
!LibV2/catalog/.gitkeep
!LibV2/catalog/cross_package_concepts.json

# =============================================================================
# Ed4All - Input/Output Directories
# =============================================================================

# Courseforge inputs (all subdirectories)
Courseforge/inputs/exam-objectives/*
!Courseforge/inputs/exam-objectives/.gitkeep
Courseforge/inputs/textbooks/*
!Courseforge/inputs/textbooks/.gitkeep
Courseforge/inputs/existing-packages/*
!Courseforge/inputs/existing-packages/.gitkeep
Courseforge/inputs/course-data/*
!Courseforge/inputs/course-data/.gitkeep

# Courseforge outputs
Courseforge/exports/*
!Courseforge/exports/.gitkeep
Courseforge/runtime/*
!Courseforge/runtime/.gitkeep

# Courseforge generated data files in scripts/
Courseforge/scripts/*.json

# DART inputs/outputs
DART/batch_output/*
!DART/batch_output/.gitkeep
DART/output/*
!DART/output/.gitkeep
DART/inputs/*
!DART/inputs/.gitkeep

# Trainforge outputs
Trainforge/output/*
!Trainforge/output/.gitkeep

