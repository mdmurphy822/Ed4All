{"bloom_level": "analyze", "chunk_id": "rdf_shacl_551_chunk_00004", "completion": "Strong RDF practice is to reuse well-known IRIs whenever possible rather than minting new ones for the same concept. Standard vocabularies such as FOAF for people, schema.org for general entities, and Dublin Core for documents already define IRIs for thousands of common concepts. Learners should be able to break this down and explain the parts of iri.", "content_type": "rationale", "decision_capture_id": "EVT_84193bd054c7f27b", "instruction_variant": 0, "lo_refs": ["co-02", "to-01"], "prompt": "Analyze the structure of iri and identify its most important relationships.", "provider": "mock", "requires_source_citation": false, "schema_version": "v1", "seed": 20, "source_chunk_id": "rdf_shacl_551_chunk_00004", "source_citation": "[rdf_shacl_551_chunk_00004]", "source_references": [{"confidence": 0.3, "role": "primary", "sourceId": "dart:owl2_primer_accessible#s1"}, {"confidence": 0.95, "role": "contributing", "sourceId": "dart:rdf11_primer_accessible#s7"}, {"confidence": 0.85, "role": "corroborating", "sourceId": "dart:rdf11_concepts_accessible#s2"}], "template_id": "analyze._default"}
