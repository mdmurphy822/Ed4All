{"bloom_level": "create", "chunk_id": "rdf_shacl_551_chunk_00061", "completion": "RDF literals carry an optional language tag (BCP 47), and RDFS labels and comments are typed as rdf:langString when a tag is present. Imagine a consumer who finds your data by following links from a colleague's graph: they see ex:doc-1 ex:author ex:alice and have never seen ex:author before. Learners should be able to generate a fresh example or application of to 02 sub skill.", "content_type": "explanation", "decision_capture_id": "EVT_9fdd91a9803b0092", "instruction_variant": 0, "lo_refs": ["to-02", "co-09"], "prompt": "Propose a new explanation or analogy for to 02 sub skill that would help a novice learner.", "provider": "mock", "requires_source_citation": false, "schema_version": "v1", "seed": 77, "source_chunk_id": "rdf_shacl_551_chunk_00061", "source_citation": "[rdf_shacl_551_chunk_00061]", "source_references": [{"confidence": 0.3, "role": "primary", "sourceId": "dart:owl2_primer_accessible#s3"}], "template_id": "create.explanation"}
