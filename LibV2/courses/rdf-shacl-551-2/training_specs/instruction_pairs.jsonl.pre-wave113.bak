{"bloom_level": "understand", "chunk_id": "rdf_shacl_551_chunk_00130", "completion": "This example reuses the small library dataset from the Week 6 application activity. Books connect to authors via :author and to loan dates via :loanedOn . A proficient learner can explain this about pattern to remember in their own words.", "content_type": "example", "decision_capture_id": "EVT_09c2002890e1a2f8", "instruction_variant": 0, "lo_refs": ["co-13", "to-03"], "prompt": "Describe what the example of pattern to remember is meant to illustrate.", "provider": "mock", "requires_source_citation": false, "schema_version": "v1", "seed": 146, "source_chunk_id": "rdf_shacl_551_chunk_00130", "source_citation": "[rdf_shacl_551_chunk_00130]", "source_references": [{"confidence": 0.85, "extractor": "content-generator-v1", "role": "primary", "sourceId": "dart:owl2_primer_accessible#s6"}], "template_id": "understand.example"}
