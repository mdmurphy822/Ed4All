{"bloom_level": "create", "chunk_id": "rdf_shacl_551_chunk_00291", "completion": "Week 12 · CO-29 · Capstone scenario emphasizing public publication and federation You are a contractor for ScholarLink, a small non-profit consortium of open-access publishers. ScholarLink wants to publish a small linked-data registry of about twenty open-access journal articles as a proof-of-concept for a future federated scholarly-search service. A proficient learner can generate a fresh example or application of iri.", "content_type": "real_world_scenario", "decision_capture_id": "EVT_36abe6b4a5651fcf", "instruction_variant": 0, "lo_refs": ["co-29", "co-18", "to-07", "to-04"], "prompt": "Design a short activity that teaches iri to a learner new to the material.", "provider": "mock", "requires_source_citation": false, "schema_version": "v1", "seed": 307, "source_chunk_id": "rdf_shacl_551_chunk_00291", "source_citation": "[rdf_shacl_551_chunk_00291]", "source_references": [{"confidence": 0.8, "extractor": "source-router", "role": "primary", "sourceId": "dart:owl2_primer_accessible#s12"}], "template_id": "create._default"}
